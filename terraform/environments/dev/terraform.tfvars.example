project_id = "mogu-501309"
region     = "asia-northeast1"
owner      = "m-maehara"

# Firebase Terraform bootstrap: your GCP user for SA impersonation (see docs/SETUP.md §6).
# terraform_firebase_impersonators = ["user:you@example.com"]

# Phase 1: leave app_image at the default placeholder for the first apply,
# then set it to your pushed image and re-apply.
# app_image = "asia-northeast1-docker.pkg.dev/mogu-501309/web/web:latest"

# Billing budget: find the ID with `gcloud billing accounts list`.
billing_account_id = "000000-000000-000000"
# monthly_budget_jpy = 3000

# GitHub Actions WIF (default: protofield-labs/mogu).
# github_repository = "owner/repo"

# Phase 2: flip to true to wire Cloud Run to Cloud SQL.
# enable_db_connection = false

# #47: Places API key + Vertex AI IAM for Cloud Run (Maps Platform billing required).
# enable_external_apis = true

# #43: Agent Engine Reasoning Engines (requires enable_external_apis).
# enable_agent_engine = true

# Slack alerts (Monitoring + Billing budget). One-time Console OAuth setup:
#   GCP Console → Monitoring → Alerting → Edit notification channels → Slack
# Then: gcloud monitoring channels list --project=PROJECT_ID --filter='type="slack"'
# slack_notification_channel_id = "projects/PROJECT_ID/notificationChannels/CHANNEL_ID"
# slack_channel_name = "#gcp-alerts"
#
# Budget → Slack (Pub/Sub + Cloud Function): create an Incoming Webhook for
# #mogu-lab in your Slack app, then set:
# slack_budget_webhook_url = "https://hooks.slack.com/services/..."

# #355: incident-agent (requires enable_db_connection = true).
# enable_incident_agent = true
# Publish this image before enabling incident-agent; Cloud Run rejects missing images.
# incident_agent_image = "asia-northeast1-docker.pkg.dev/mogu-501309/incident-agent/incident-agent:VERSION"
# incident_agent_slack_domain = "incident-slack.example.com"
# incident_agent_slack_signing_secret = "..."
# incident_agent_slack_bot_token = "xoxb-..."
# incident_agent_slack_team_id = "T01234567"
# incident_agent_slack_channel_id = "C01234567"
# incident_agent_slack_allowed_user_ids = "U01234567,U09876543"
# incident_agent_github_token = "github_pat_..."
