# Local development: Cloud SQL Auth Proxy on 127.0.0.1:5432 (see docs/SETUP.md §5).
# Replace PASSWORD with: gcloud secrets versions access latest --secret=dev-db-password --project=mogu-501309
DATABASE_URL="postgresql://app_user:PASSWORD@127.0.0.1:5432/app"

# Firebase Web SDK (public; baked at build time). After `terraform apply`, run:
#   terraform -chdir=terraform/environments/dev output -json firebase_web_config
# Or use Auth Emulator dummy values below.
NEXT_PUBLIC_FIREBASE_API_KEY="dummy-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="localhost"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="demo-mogu"
NEXT_PUBLIC_FIREBASE_APP_ID="1:demo-mogu:web:local"

# Auth Emulator (client + Admin SDK). Start with: firebase emulators:start --only auth
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST="127.0.0.1:9099"
FIREBASE_AUTH_EMULATOR_HOST="127.0.0.1:9099"

# Admin SDK project ID. MUST match the client project ID, or verifyIdToken
# rejects every token (aud mismatch):
#   - Auth Emulator: use "demo-mogu" (same as NEXT_PUBLIC_FIREBASE_PROJECT_ID above)
#   - Real Firebase (gcloud auth application-default login): use "mogu-501309"
GOOGLE_CLOUD_PROJECT="demo-mogu"

# Google Maps JavaScript API (client-side map rendering for #130 / #185).
# Requires Maps JavaScript API enabled + HTTP referrer restriction.
# After `terraform apply` with enable_external_apis=true:
#   terraform -chdir=terraform/environments/dev output -raw maps_js_api_key
# See docs/SETUP.md §7.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Places API (server-side: coordinates, photos, Japanese place names).
# After `terraform apply` with enable_external_apis=true:
#   gcloud secrets versions access latest --secret=dev-places-api-key --project=mogu-501309
# See docs/SETUP.md §7.
PLACES_API_KEY=""
